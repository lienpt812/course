{
  "models": [
    {
      "id": "AuthModel",
      "name": "AuthModel",
      "generator": "random(edge_coverage(100))",
      "startElementId": "v_GuestOnCourses",
      "actions": [
        "gwGuard_emailInvalid = true;",
        "gwGuard_forgotEmailExists = true;",
        "gwGuard_forgotEmailMissing = true;",
        "gwGuard_forgotRateLimitedBlocked = true;",
        "gwGuard_loggedIn = true;",
        "gwGuard_loginCredentialsOk = true;",
        "gwGuard_loginWillFail = true;",
        "gwGuard_passwordWeak = true;",
        "gwGuard_profileUpdateInvalid = true;",
        "gwGuard_profileUpdateOk = true;",
        "gwGuard_registerDuplicate = true;",
        "gwGuard_registerInstructorOk = true;",
        "gwGuard_registerRoleFieldsInvalid = true;",
        "gwGuard_registerStudentOk = true;",
        "gwGuard_resetReady = true;",
        "gwGuard_roleAdmin = true;",
        "gwGuard_roleInstructor = true;",
        "gwGuard_roleStudent = true;"
      ],
      "vertices": [
        {
          "id": "v_GuestOnCourses",
          "name": "v_GuestOnCourses",
          "properties": {
            "description": "Guest (chua dang nhap) dang xem /courses. localStorage khong co access_token. NavBar hien 'Dang nhap', khong co 'Logout'.",
            "url": "/courses",
            "uiAssert": "h1=Khoa Hoc, Logout NOT visible",
            "requirement": "REQ-A-GUEST"
          }
        },
        {
          "id": "v_LoginPage",
          "name": "v_LoginPage",
          "properties": {
            "description": "Trang /login. Form email+password, button Dang nhap, link Dang ky ngay, link Quen mat khau. p.text-red-600 khi co loi.",
            "url": "/login",
            "uiAssert": "h1=Dang nhap, input[type=email], input[type=password], button[type=submit]",
            "requirement": "REQ-A-LOGIN"
          }
        },
        {
          "id": "v_RegisterPage",
          "name": "v_RegisterPage",
          "properties": {
            "description": "Trang /register. Role STUDENT|INSTRUCTOR. STUDENT can student_major hoac learning_goal. INSTRUCTOR bat buoc expertise>=3 ky tu. Password regex ^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d).{8,64}$.",
            "url": "/register",
            "uiAssert": "h1=Dang ky, select[role], conditional fields",
            "requirement": "REQ-A-REGISTER"
          }
        },
        {
          "id": "v_ForgotPasswordPage",
          "name": "v_ForgotPasswordPage",
          "properties": {
            "description": "Trang /forgot-password. POST /auth/forgot-password luon 200 (chong enumeration). Email ton tai: response co reset_token hien thi dev UI (div.bg-emerald-50 + p.font-mono).",
            "url": "/forgot-password",
            "uiAssert": "h1=Quen mat khau, input[type=email]",
            "requirement": "REQ-A-FORGOT"
          }
        },
        {
          "id": "v_ResetPasswordPage",
          "name": "v_ResetPasswordPage",
          "properties": {
            "description": "Trang /reset-password?token=. Token pre-fill tu URL param (useSearchParams). FE validate: newPwd != confirmPwd -> error. Success -> navigate('/login').",
            "url": "/reset-password",
            "uiAssert": "h1=Dat lai mat khau, token input pre-filled from URL",
            "requirement": "REQ-A-RESET"
          }
        },
        {
          "id": "v_StudentDashboard",
          "name": "v_StudentDashboard",
          "properties": {
            "description": "/student/dashboard. 4 stat cards, bang registrations, section Chung Chi. API: GET /dashboards/student + /registrations + /courses + /certificates/me.",
            "url": "/student/dashboard",
            "uiAssert": "h1=Dashboard Hoc Vien",
            "requirement": "REQ-A-DASH-STUDENT"
          }
        },
        {
          "id": "v_InstructorDashboard",
          "name": "v_InstructorDashboard",
          "properties": {
            "description": "/instructor/dashboard. Stat cards, bang courses, quan ly section/lesson. API: GET /dashboards/instructor.",
            "url": "/instructor/dashboard",
            "uiAssert": "h1=Dashboard Giang Vien",
            "requirement": "REQ-A-DASH-INSTRUCTOR"
          }
        },
        {
          "id": "v_AdminDashboard",
          "name": "v_AdminDashboard",
          "properties": {
            "description": "/admin/dashboard. 6 stat cards, bang registrations voi filter #admin-filter-course-select / #admin-filter-status-select, nut bulk-approve[data-testid=admin-bulk-approve].",
            "url": "/admin/dashboard",
            "uiAssert": "h1=Quan Tri He Thong, filter selects visible",
            "requirement": "REQ-A-DASH-ADMIN"
          }
        },
        {
          "id": "v_ProfilePage",
          "name": "v_ProfilePage",
          "properties": {
            "description": "/profile. GET /auth/me de load. PATCH /auth/me de update. INSTRUCTOR: expertise khong duoc rong neu trong payload. STUDENT: phai con student_major hoac learning_goal.",
            "url": "/profile",
            "uiAssert": "h1=Profile, button Luu",
            "requirement": "REQ-A-PROFILE"
          }
        }
