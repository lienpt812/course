            "uiAssert": "p.text-red-600 OR saveSectionButton disabled",
            "requirement": "REQ-F-SEC-ERR"
          }
        },
        {
          "id": "v_LessonCreated",
          "name": "v_LessonCreated",
          "properties": {
            "description": "POST /learning/lessons thanh cong. Cross-check: GET outline tra at least 1 lesson trong section.",
            "apiEndpoint": "POST /api/v1/learning/lessons",
            "apiVerify": "GET outline has lessons.size() >= 1",
            "requirement": "REQ-F-LESSON-OK"
