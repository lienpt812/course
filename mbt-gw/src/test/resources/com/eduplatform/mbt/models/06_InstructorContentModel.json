        },
        {
          "id": "v_LessonCreateError",
          "name": "v_LessonCreateError",
          "properties": {
            "description": "FE: title <2 ky tu -> button disabled. BE: section khong ton tai -> 404.",
            "uiAssert": "p.text-red-600 OR saveLessonButton disabled",
            "requirement": "REQ-F-LESSON-ERR"
          }
