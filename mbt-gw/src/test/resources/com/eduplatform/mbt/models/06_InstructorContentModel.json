      "startElementId": "v_InstructorDashboard",
      "actions": [
        "gwGuard_createCapacityInvalid = true;",
        "gwGuard_createCourseFormAllValid = true;",
        "gwGuard_createDescriptionInvalid = true;",
        "gwGuard_createHoursInvalid = true;",
        "gwGuard_createImageInvalid = true;",
        "gwGuard_createTitleInvalid = true;",
        "gwGuard_foreignCourseExists = true;",
        "gwGuard_lessonCreateReady = true;",
        "gwGuard_lessonFormValid = true;",
        "gwGuard_lessonTitleInvalid = true;",
        "gwGuard_ownedCourseExists = true;",
        "gwGuard_ownedDraftExists = true;",
        "gwGuard_ownedPublishedExists = true;",
        "gwGuard_sectionFormValid = true;",
        "gwGuard_sectionTitleInvalid = true;"
      ],
      "vertices": [
        {
          "id": "v_InstructorDashboard",
          "name": "v_InstructorDashboard",
          "properties": {
            "description": "/instructor/dashboard. GET /dashboards/instructor: total_courses, total_students, total_registrations, list courses. Section quan ly section/lesson voi select 'Chon khoa hoc'. Nut 'Them khoa hoc'. Impl: sync ownedCourseExists, ownedDraftExists, ownedPublishedExists tu API.",
            "url": "/instructor/dashboard",
            "apiEndpoint": "GET /api/v1/dashboards/instructor",
            "uiAssert": "h1=Dashboard Giang Vien",
            "syncGuards": "ownedCourseExists, ownedDraftExists, ownedPublishedExists, foreignCourseExists",
            "requirement": "REQ-F-DASH"
          }
        },
        {
          "id": "v_CourseCreateForm",
          "name": "v_CourseCreateForm",
          "properties": {
            "description": "Form tao course inline (showCreateForm=true). Fields: title(3-255), slug(auto tu title neu trong, <=255), description(>=20), category, image_url(phai bat dau https://), maxCapacity(1-10000), estimatedHours(1-1000), level(Beginner/Intermediate/Advanced), status(DRAFT/PUBLISHED/COMING_SOON). Nut 'Luu khoa hoc' + 'Huy'.",
            "uiAssert": "titleInput visible, saveCourseButton visible",
            "requirement": "REQ-F-FORM"
          }
        },
        {
          "id": "v_CourseCreated",
          "name": "v_CourseCreated",
          "properties": {
            "description": "POST /courses thanh cong. Course moi xuat hien trong bang. Cross-check: GET /courses/{id} tra du lieu dung (title/status/instructor_id).",
            "apiEndpoint": "POST /api/v1/courses",
            "uiAssert": "course rows >= 1 in table",
            "apiVerify": "GET /api/v1/courses/{newId} -> title matches, instructor_id matches",
            "requirement": "REQ-F-CREATE-OK"
          }
        },
        {
          "id": "v_CourseCreateError",
          "name": "v_CourseCreateError",
          "properties": {
            "description": "FE validation fail (truoc khi goi API) -> p.text-red-600 hien. Cac loi: 'Ten khoa hoc phai tu 3 den 255 ky tu', 'Mo ta can it nhat 20 ky tu', 'Slug khong hop le', 'URL anh khong hop le', v.v.",
            "uiAssert": "p.text-red-600 visible, no API call for course create",
            "requirement": "REQ-F-CREATE-ERR"
          }
        },
        {
          "id": "v_CourseEditDetail",
          "name": "v_CourseEditDetail",
          "properties": {
            "description": "/courses/:id. Instructor la chu khoa hoc, status != PUBLISHED -> nut 'Chinh sua' hien. CourseOutlineManager xuong phia duoi. Impl: open myOwnedDraftCourse.",
            "url": "/courses/:courseId",
            "uiAssert": "editButton 'Chinh sua' visible, backToList visible",
            "requirement": "REQ-F-EDIT-ENTER"
          }
        },
        {
          "id": "v_CourseEditForm",
          "name": "v_CourseEditForm",
          "properties": {
            "description": "setIsEditing=true tren CourseDetailPage. Edit form inline. Nut 'Luu' va 'Huy'. Impl: click edit button.",
            "uiAssert": "backToList visible, save/cancel buttons visible",
            "requirement": "REQ-F-EDIT-FORM"
          }
        },
        {
          "id": "v_CourseEditForbiddenPublished",
          "name": "v_CourseEditForbiddenPublished",
          "properties": {
            "description": "Course da PUBLISHED -> FE hien 'Khoa hoc da published - khong the chinh sua'. Nut 'Chinh sua' khong hien. Impl: open myOwnedPublishedCourse. Seed can co PUBLISHED course.",
            "url": "/courses/:courseId",
            "uiAssert": "publishedLockMsg 'Khoa hoc da published...' visible, editButton NOT visible",
            "requirement": "REQ-F-EDIT-BLOCKED-PUBLISHED"
          }
        },
        {
          "id": "v_CourseEditForbiddenNotOwner",
          "name": "v_CourseEditForbiddenNotOwner",
          "properties": {
            "description": "Instructor khac hoac student -> khong thay nut 'Chinh sua'. BE PATCH /courses/{id} se tra 403 'Cannot update another instructor course'. Impl: open foreignCourse.",
            "url": "/courses/:courseId",
            "uiAssert": "editButton NOT visible",
            "expectedStatus": 403,
            "requirement": "REQ-F-EDIT-BLOCKED-NOT-OWNER"
          }
        },
        {
          "id": "v_CourseUpdated",
          "name": "v_CourseUpdated",
          "properties": {
            "description": "PATCH /courses/{id} thanh cong. course detail reload, title cap nhat. Cross-check: assertSuccessEnvelope + title chua 'MBT Updated'.",
            "apiEndpoint": "PATCH /api/v1/courses/{id}",
            "uiAssert": "h1=updated title",
            "requirement": "REQ-F-UPDATE-OK"
          }
        },
        {
          "id": "v_SectionManagerOpen",
          "name": "v_SectionManagerOpen",
          "properties": {
            "description": "Quan ly section/lesson (InstructorDashboard: select course -> fetch outline). Co input 'Ten section', nut 'Luu section'. Co select 'Chon section', input 'Ten lesson', nut 'Luu lesson'. Impl: ensure course selected in dropdown.",
            "uiAssert": "sectionTitleInput visible, saveSectionButton visible",
            "requirement": "REQ-F-SECMGR"
          }
        },
        {
          "id": "v_SectionCreated",
          "name": "v_SectionCreated",
