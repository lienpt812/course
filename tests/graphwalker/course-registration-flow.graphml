<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns">
  <key id="d0" for="node" attr.name="name" attr.type="string"/>
  <key id="d1" for="edge" attr.name="name" attr.type="string"/>
  <graph id="CourseRegistrationFlow" edgedefault="directed">
    <node id="n0"><data key="d0">v_GuestOnCourses</data></node>
    <node id="n1"><data key="d0">v_LoginPage</data></node>
    <node id="n2"><data key="d0">v_StudentDashboard</data></node>
    <node id="n3"><data key="d0">v_PendingRegistration</data></node>
    <node id="n4"><data key="d0">v_AdminDashboard</data></node>
    <node id="n5"><data key="d0">v_ConfirmedRegistration</data></node>
    <node id="n6"><data key="d0">v_LearningPage</data></node>
    <node id="n7"><data key="d0">v_CertificateIssued</data></node>
    <node id="n8"><data key="d0">v_RejectedRegistration</data></node>

    <edge id="e0" source="n0" target="n1"><data key="d1">e_GoToLogin</data></edge>
    <edge id="e1" source="n1" target="n2"><data key="d1">e_LoginAsStudent</data></edge>
    <edge id="e2" source="n2" target="n3"><data key="d1">e_RegisterCourse</data></edge>
    <edge id="e3" source="n3" target="n4"><data key="d1">e_AdminOpenPendingList</data></edge>
    <edge id="e4" source="n4" target="n5"><data key="d1">e_AdminApprove</data></edge>
    <edge id="e5" source="n4" target="n8"><data key="d1">e_AdminRejectWhenFull</data></edge>
    <edge id="e6" source="n5" target="n6"><data key="d1">e_StartLearning</data></edge>
    <edge id="e7" source="n6" target="n7"><data key="d1">e_CompleteCourseAndIssueCertificate</data></edge>
    <edge id="e8" source="n8" target="n0"><data key="d1">e_BackToCourses</data></edge>
    <edge id="e9" source="n7" target="n0"><data key="d1">e_LogoutToCourses</data></edge>
  </graph>
</graphml>
