{"models":[{"id":"CourseStatusLifecycleModel","name":"Course_Status_Lifecycle","generator":"random(edge_coverage(100))","startElementId":"v_DraftCourse","vertices":[{"id":"v_DraftCourse","name":"v_DraftCourse","actions":["currentRole = 'INSTRUCTOR';","courseStatus = 'DRAFT';","sectionCount = 0;","lessonCount = 0;","registrationCount = 0;"],"properties":{"description":"Khóa học mới tạo - status DRAFT. Instructor có thể chỉnh sửa, thêm section/lesson. Học sinh không thấy trong danh sách"}},{"id":"v_PublishedCourse","name":"v_PublishedCourse","properties":{"description":"Khóa học PUBLISHED: hiện trong danh sách công khai, học sinh có thể đăng ký (nếu trong thời gian mở). Instructor KHÔNG thể chỉnh sửa nữa"}},{"id":"v_ComingSoonCourse","name":"v_ComingSoonCourse","properties":{"description":"Khóa học COMING_SOON: hiện trong danh sách nhưng chưa mở đăng ký"}},{"id":"v_ArchivedCourse","name":"v_ArchivedCourse","properties":{"description":"Khóa học ARCHIVED: ẩn khỏi danh sách công khai. Các đơn PENDING bị tự động CANCELLED"}},{"id":"v_RegistrationOpenWindow","name":"v_RegistrationOpenWindow","properties":{"description":"Cửa sổ đăng ký mở: registration_open_at <= now <= registration_close_at. Học sinh đăng ký được"}},{"id":"v_RegistrationClosedWindow","name":"v_RegistrationClosedWindow","properties":{"description":"Ngoài cửa sổ đăng ký: now < registration_open_at hoặc now > registration_close_at. Lỗi 'Course is not open for registration'"}},{"id":"v_CapacityFull","name":"v_CapacityFull","properties":{"description":"Lớp đầy: confirmed_slots >= max_capacity. Đăng ký mới → WAITLIST"}},{"id":"v_CapacityAvailable","name":"v_CapacityAvailable","properties":{"description":"Còn slot: confirmed_slots < max_capacity. Đăng ký mới → PENDING (chờ duyệt)"}},{"id":"v_EditBlockedPublished","name":"v_EditBlockedPublished","properties":{"description":"Cố chỉnh sửa khóa PUBLISHED: nút Chỉnh sửa bị ẩn, hiện thông báo 'Khóa học đã published'"}}],"edges":[{"id":"e_PublishFromDraft","name":"e_PublishFromDraft","sourceVertexId":"v_DraftCourse","targetVertexId":"v_PublishedCourse","actions":["courseStatus = 'PUBLISHED';"],"properties":{"description":"Đổi status DRAFT → PUBLISHED qua form chỉnh sửa"}},{"id":"e_SetComingSoon","name":"e_SetComingSoon","sourceVertexId":"v_DraftCourse","targetVertexId":"v_ComingSoonCourse","actions":["courseStatus = 'COMING_SOON';"],"properties":{"description":"Đổi status DRAFT → COMING_SOON"}},{"id":"e_PublishFromComingSoon","name":"e_PublishFromComingSoon","sourceVertexId":"v_ComingSoonCourse","targetVertexId":"v_PublishedCourse","actions":["courseStatus = 'PUBLISHED';"],"properties":{"description":"Đổi COMING_SOON → PUBLISHED"}},{"id":"e_ArchiveFromPublished","name":"e_ArchiveFromPublished","sourceVertexId":"v_PublishedCourse","targetVertexId":"v_ArchivedCourse","actions":["courseStatus = 'ARCHIVED';","registrationCount = 0;"],"properties":{"description":"PUBLISHED → ARCHIVED: các đơn PENDING bị tự động CANCELLED"}},{"id":"e_ArchiveFromDraft","name":"e_ArchiveFromDraft","sourceVertexId":"v_DraftCourse","targetVertexId":"v_ArchivedCourse","actions":["courseStatus = 'ARCHIVED';"],"properties":{"description":"DRAFT → ARCHIVED"}},{"id":"e_TryEditPublished","name":"e_TryEditPublished","sourceVertexId":"v_PublishedCourse","targetVertexId":"v_EditBlockedPublished","properties":{"description":"Instructor cố chỉnh sửa khóa PUBLISHED - bị chặn"}},{"id":"e_BackToPublished","name":"e_BackToPublished","sourceVertexId":"v_EditBlockedPublished","targetVertexId":"v_PublishedCourse"},{"id":"e_CheckRegistrationWindow","name":"e_CheckRegistrationWindowOpen","sourceVertexId":"v_PublishedCourse","targetVertexId":"v_RegistrationOpenWindow","properties":{"description":"Trong cửa sổ đăng ký - học sinh có thể đăng ký"}},{"id":"e_CheckRegistrationClosed","name":"e_CheckRegistrationWindowClosed","sourceVertexId":"v_PublishedCourse","targetVertexId":"v_RegistrationClosedWindow","properties":{"description":"Ngoài cửa sổ đăng ký - lỗi 'Course is not open for registration'"}},{"id":"e_CheckCapacityAvailable","name":"e_CheckCapacityAvailable","sourceVertexId":"v_RegistrationOpenWindow","targetVertexId":"v_CapacityAvailable","properties":{"description":"Còn slot trống - đăng ký → PENDING"}},{"id":"e_CheckCapacityFull","name":"e_CheckCapacityFull","sourceVertexId":"v_RegistrationOpenWindow","targetVertexId":"v_CapacityFull","properties":{"description":"Lớp đầy - đăng ký → WAITLIST"}},{"id":"e_BackToPublishedFromOpen","name":"e_BackToPublished","sourceVertexId":"v_RegistrationOpenWindow","targetVertexId":"v_PublishedCourse"},{"id":"e_BackToPublishedFromClosed","name":"e_BackToPublished","sourceVertexId":"v_RegistrationClosedWindow","targetVertexId":"v_PublishedCourse"},{"id":"e_BackToPublishedFromFull","name":"e_BackToPublished","sourceVertexId":"v_CapacityFull","targetVertexId":"v_PublishedCourse"},{"id":"e_BackToPublishedFromAvailable","name":"e_BackToPublished","sourceVertexId":"v_CapacityAvailable","targetVertexId":"v_PublishedCourse"},{"id":"e_IncreaseCapacity","name":"e_IncreaseCapacity","sourceVertexId":"v_CapacityFull","targetVertexId":"v_CapacityAvailable","properties":{"description":"Tăng max_capacity → tự động promote waitlist"}},{"id":"e_BackToDraftFromArchived","name":"e_BackToDraft","sourceVertexId":"v_ArchivedCourse","targetVertexId":"v_DraftCourse","actions":["courseStatus = 'DRAFT';"],"properties":{"description":"ARCHIVED → DRAFT để chỉnh sửa lại"}}]}],"selectedModelIndex":0}
