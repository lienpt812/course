{
  "name": "InstructorCourseRegistrationModel",
  "models": [
    {
      "id": "CourseRegistration",
      "name": "CourseRegistration",
      "generator": "random(edge_coverage(100))",
      "startElement": "v_InstructorDashboard",
      "vertices": [
        {
          "id": "v_Start",
          "name": "v_Start",
          "properties": {
            "description": "Starting point"
          }
        },
        {
          "id": "v_InstructorDashboard",
          "name": "v_InstructorDashboard",
          "properties": {
            "description": "Instructor is on the Dashboard"
          }
        },
        {
          "id": "v_RegistrationForm",
          "name": "v_RegistrationForm",
          "properties": {
            "description": "Registration form is displayed"
          }
        },
        {
          "id": "v_CourseDetailDisplay",
          "name": "v_CourseDetailDisplay",
          "properties": {
            "description": "Course detail page is shown (optional)"
          }
        },
        {
          "id": "v_ValidationErrorHint",
          "name": "v_ValidationErrorHint",
          "properties": {
            "description": "Validation error message is shown"
          }
        }
      ],
      "edges": [
        {
          "id": "e_Init",
          "name": "e_Init",
          "sourceVertexId": "v_Start",
          "targetVertexId": "v_InstructorDashboard",
          "properties": {
            "description": "Initialize and go to Dashboard"
          }
        },
        {
          "id": "e_ClickRegisterCourseButton",
          "name": "e_ClickRegisterCourseButton",
          "sourceVertexId": "v_InstructorDashboard",
          "targetVertexId": "v_RegistrationForm",
          "properties": {
            "description": "Click button to open registration form"
          }
        },
        {
          "id": "e_SubmitValidForm",
          "name": "e_SubmitValidForm",
          "sourceVertexId": "v_RegistrationForm",
          "targetVertexId": "v_InstructorDashboard",
          "properties": {
            "description": "Submit valid form → back to Dashboard with new course"
          }
        },
        {
          "id": "e_SubmitInvalidForm",
          "name": "e_SubmitInvalidForm",
          "sourceVertexId": "v_RegistrationForm",
          "targetVertexId": "v_ValidationErrorHint",
          "properties": {
            "description": "Submit invalid form → show validation error"
          }
        },
        {
          "id": "e_InputRequiredFields",
          "name": "e_InputRequiredFields",
          "sourceVertexId": "v_RegistrationForm",
          "targetVertexId": "v_ValidationErrorHint",
          "properties": {
            "description": "Input missing required fields"
          }
        },
        {
          "id": "e_BackToDashboard",
          "name": "e_BackToDashboard",
          "sourceVertexId": "v_CourseDetailDisplay",
          "targetVertexId": "v_InstructorDashboard",
          "properties": {
            "description": "Back to Dashboard from course detail"
          }
        }
      ]
    }
  ]
}