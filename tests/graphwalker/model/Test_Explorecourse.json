{
  "models": [
    {
      "id": "ExploreCourseModel",
      "name": "ExploreCourseModel_Final",
      "generator": "random(edge_coverage(100))",
      "startElementId": "v_CourseListPage",

      "vertices": [
        {
          "id": "v_CourseListPage",
          "name": "CourseListPage",
          "actions": [
            "isLoggedIn = false;",
            "currentRole = '';",
            "selectedCourseId = 0;",
            "filterCategory = 'all';",
            "filterLevel = 'all';",
            "remainingSlots = 0;",
            "isCourseFull = false;"
          ],
          "properties": {
            "description": "Hiển thị danh sách course PUBLISHED"
          }
        },

        {
          "id": "v_CourseDetailPage",
          "name": "CourseDetailPage",
          "actions": [
            "remainingSlots = 5;",
            "isCourseFull = remainingSlots == 0;"
          ],
          "properties": {
            "description": "Chi tiết khóa học + slot"
          }
        },

        {
          "id": "v_LoginPage",
          "name": "LoginPage"
        },

        {
          "id": "v_StudentDashboard",
          "name": "StudentDashboard"
        },

        {
          "id": "v_InstructorDashboard",
          "name": "InstructorDashboard"
        },

        {
          "id": "v_AdminDashboard",
          "name": "AdminDashboard"
        }
      ],

      "edges": [

        {
          "id": "e_FilterByCategory",
          "name": "FilterByCategory",
          "sourceVertexId": "v_CourseListPage",
          "targetVertexId": "v_CourseListPage",
          "actions": [
            "filterCategory = 'Backend';"
          ]
        },

        {
          "id": "e_FilterByLevel",
          "name": "FilterByLevel",
          "sourceVertexId": "v_CourseListPage",
          "targetVertexId": "v_CourseListPage",
          "actions": [
            "filterLevel = 'Beginner';"
          ]
        },

        {
          "id": "e_ResetFilter",
          "name": "ResetFilter",
          "sourceVertexId": "v_CourseListPage",
          "targetVertexId": "v_CourseListPage",
          "actions": [
            "filterCategory = 'all';",
            "filterLevel = 'all';"
          ]
        },

        {
          "id": "e_SearchCourse",
          "name": "SearchCourse",
          "sourceVertexId": "v_CourseListPage",
          "targetVertexId": "v_CourseListPage"
        },

        {
          "id": "e_ClickCourseCard",
          "name": "ClickCourseCard",
          "sourceVertexId": "v_CourseListPage",
          "targetVertexId": "v_CourseDetailPage",
          "guard": "selectedCourseId == 0",
          "actions": [
            "selectedCourseId = 1;"
          ]
        },

        {
          "id": "e_BackToCourseList",
          "name": "BackToCourseList",
          "sourceVertexId": "v_CourseDetailPage",
          "targetVertexId": "v_CourseListPage",
          "actions": [
            "selectedCourseId = 0;"
          ]
        },

        {
          "id": "e_GuestClickRegister",
          "name": "GuestClickRegister",
          "sourceVertexId": "v_CourseDetailPage",
          "targetVertexId": "v_LoginPage",
          "guard": "isLoggedIn == false"
        },

        {
          "id": "e_StudentRegisterCourse",
          "name": "StudentRegisterCourse",
          "sourceVertexId": "v_CourseDetailPage",
          "targetVertexId": "v_CourseDetailPage",
          "guard": "isLoggedIn == true && currentRole == 'STUDENT' && isCourseFull == false",
          "actions": [
            "remainingSlots = remainingSlots - 1;",
            "isCourseFull = remainingSlots == 0;"
          ]
        },

        {
          "id": "e_RegisterCourseFull",
          "name": "RegisterCourseFull",
          "sourceVertexId": "v_CourseDetailPage",
          "targetVertexId": "v_CourseDetailPage",
          "guard": "isLoggedIn == true && currentRole == 'STUDENT' && isCourseFull == true"
        },

        {
          "id": "e_NonStudentTryRegister",
          "name": "NonStudentTryRegister",
          "sourceVertexId": "v_CourseDetailPage",
          "targetVertexId": "v_CourseDetailPage",
          "guard": "isLoggedIn == true && currentRole != 'STUDENT'"
        },

        {
          "id": "e_GoToLogin",
          "name": "GoToLogin",
          "sourceVertexId": "v_CourseListPage",
          "targetVertexId": "v_LoginPage"
        },

        {
          "id": "e_LoginAsStudent",
          "name": "LoginAsStudent",
          "sourceVertexId": "v_LoginPage",
          "targetVertexId": "v_StudentDashboard",
          "actions": [
            "currentRole = 'STUDENT';",
            "isLoggedIn = true;"
          ]
        },

        {
          "id": "e_LoginAsInstructor",
          "name": "LoginAsInstructor",
          "sourceVertexId": "v_LoginPage",
          "targetVertexId": "v_InstructorDashboard",
          "actions": [
            "currentRole = 'INSTRUCTOR';",
            "isLoggedIn = true;"
          ]
        },

        {
          "id": "e_LoginAsAdmin",
          "name": "LoginAsAdmin",
          "sourceVertexId": "v_LoginPage",
          "targetVertexId": "v_AdminDashboard",
          "actions": [
            "currentRole = 'ADMIN';",
            "isLoggedIn = true;"
          ]
        },

        {
          "id": "e_StudentViewCourses",
          "name": "StudentViewCourses",
          "sourceVertexId": "v_StudentDashboard",
          "targetVertexId": "v_CourseListPage"
        },

        {
          "id": "e_InstructorViewCourses",
          "name": "InstructorViewCourses",
          "sourceVertexId": "v_InstructorDashboard",
          "targetVertexId": "v_CourseListPage"
        },

        {
          "id": "e_AdminViewCourses",
          "name": "AdminViewCourses",
          "sourceVertexId": "v_AdminDashboard",
          "targetVertexId": "v_CourseListPage"
        },

        {
          "id": "e_LogoutStudent",
          "name": "LogoutStudent",
          "sourceVertexId": "v_StudentDashboard",
          "targetVertexId": "v_CourseListPage",
          "actions": [
            "isLoggedIn = false;",
            "currentRole = '';",
            "selectedCourseId = 0;"
          ]
        },

        {
          "id": "e_LogoutInstructor",
          "name": "LogoutInstructor",
          "sourceVertexId": "v_InstructorDashboard",
          "targetVertexId": "v_CourseListPage",
          "actions": [
            "isLoggedIn = false;",
            "currentRole = '';",
            "selectedCourseId = 0;"
          ]
        },

        {
          "id": "e_LogoutAdmin",
          "name": "LogoutAdmin",
          "sourceVertexId": "v_AdminDashboard",
          "targetVertexId": "v_CourseListPage",
          "actions": [
            "isLoggedIn = false;",
            "currentRole = '';",
            "selectedCourseId = 0;"
          ]
        }

      ]
    }
  ],
  "selectedModelIndex": 0
}
